PORT=3000
# Origens extras (virgula). 3DEXPERIENCE (*.3dexperience.3ds.com) e GitHub Pages ja sao liberados no codigo.
CORS_ORIGIN=https://mouraenderson.github.io

# SKA BOM Service (PR 3) — preferir THREEDX_*; SPACE_URL/SECURITY_CONTEXT sao fallback legado.
# NUNCA usar GitHub Pages, widget URL ou assets/js como THREEDX_SPACE_URL.
THREEDX_SPACE_URL=https://r1132100929518-us1-space.3dexperience.3ds.com/enovia
THREEDX_PASSPORT_URL=https://r1132100929518-eu1.iam.3dexperience.3ds.com
THREEDX_SECURITY_CONTEXT=ctx::VPLMProjectLeader.Company Name.CS_IMPLANTACAO
THREEDX_USERNAME=
THREEDX_PASSWORD=
# cas | auto | cookie-only | basic
THREEDX_AUTH_MODE=cas

# Valores: bearer | cookie | cas | basic
# Produção Render: preferir THREEDX_AUTH_MODE=cas com THREEDX_USERNAME/THREEDX_PASSWORD.
# ENOVIA_COOKIE expira (~2h); CAS renova sessão automaticamente.
BOM_SERVICE_MODE=dseng

# Paginação dseng EngInstance (PR 3) — max 20 páginas x 100 = 2000 instâncias por pai
DSENG_MAX_INSTANCE_PAGES=20

# Fallback legado (tambem usado por /api/bom/resolve)
SPACE_URL=https://r1132100929518-us1-space.3dexperience.3ds.com/enovia
SECURITY_CONTEXT=ctx::VPLMProjectLeader.Company Name.CS_IMPLANTACAO

# Escolha uma forma de autenticação para o backend.
# Para produção, prefira token OAuth/3DEXPERIENCE service account quando disponível.
ENOVIA_BEARER_TOKEN=
ENO_CSRF_TOKEN=
ENOVIA_COOKIE=

BOM_MAX_ITEMS=20000
BOM_PAGE_SIZE=100
BOM_MAX_DEPTH=40
AUTO_CSRF=true
