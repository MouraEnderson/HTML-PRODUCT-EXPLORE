{
  "info": {
    "name": "CAS Login — Tenant R1132100929518",
    "description": "Fluxo Postman Primer 3DEXPERIENCE: Login Ticket → CAS Service Login → CSRF.\n\nPreencher PASSPORT_URL, USERNAME, PASSWORD no environment antes de executar.\nOrdem: 1 → 2 → 3. Depois rode Expand-Item-DEC015 (requests 1-3).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0 — Get Login Ticket",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('ticket status 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('lt present', function () { pm.expect(body.lt).to.be.a('string').and.not.empty; });",
              "pm.environment.set('LT', body.lt);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Accept", "value": "application/json" }
        ],
        "url": "{{PASSPORT_URL}}/login?action=get_auth_params"
      }
    },
    {
      "name": "1 — CAS Service Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('CAS login redirects or sets session', function () {",
              "  pm.expect([200, 302, 303]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/x-www-form-urlencoded;charset=UTF-8" },
          { "key": "Accept", "value": "text/html,application/json" }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "lt", "value": "{{LT}}" },
            { "key": "username", "value": "{{USERNAME}}" },
            { "key": "password", "value": "{{PASSWORD}}" },
            { "key": "rememberMe", "value": "no" }
          ]
        },
        "url": "{{PASSPORT_URL}}/login?service={{CSRF_SERVICE_URL_ENCODED}}"
      }
    },
    {
      "name": "2 — GET CSRF",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('CSRF status 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "const csrf = body.csrf || body;",
              "pm.environment.set('CSRF_NAME', csrf.name || 'ENO_CSRF_TOKEN');",
              "pm.environment.set('CSRF_VALUE', csrf.value || body.token || '');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Accept", "value": "application/json" }
        ],
        "url": "{{SPACE_URL}}/resources/v1/application/CSRF"
      }
    },
    {
      "name": "3 — GET EngItem CJ MESA",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Accept", "value": "application/json" },
          { "key": "SecurityContext", "value": "{{SECURITY_CONTEXT}}" }
        ],
        "url": "{{SPACE_URL}}/resources/v1/modeler/dseng/dseng:EngItem/{{ROOT_ID}}"
      }
    }
  ]
}
